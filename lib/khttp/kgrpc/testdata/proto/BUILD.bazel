load("@rules_go//go:def.bzl", "go_library")
load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

proto_library(
    name = "test_proto",
    srcs = ["test.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "test_go_proto",
    compilers = ["//bazel/go:go_grpc"],
    importpath = "github.com/ccontavalli/enkit/lib/khttp/kgrpc/testdata/proto",
    proto = ":test_proto",
    visibility = ["//visibility:public"],
)

go_library(
    name = "proto",
    embed = [
        ":test_go_proto",
    ],
    importpath = "github.com/ccontavalli/enkit/lib/khttp/kgrpc/testdata/proto",
    visibility = ["//visibility:public"],
)
